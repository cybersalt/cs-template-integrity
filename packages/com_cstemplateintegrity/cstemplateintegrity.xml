<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>COM_CSTEMPLATEINTEGRITY</name>
    <author>Cybersalt</author>
    <creationDate>April 2026</creationDate>
    <copyright>Copyright (C) 2026 Cybersalt. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later</license>
    <authorEmail>support@cybersalt.com</authorEmail>
    <authorUrl>https://cybersalt.com</authorUrl>
    <version>2.0.0</version>
    <description>COM_CSTEMPLATEINTEGRITY_XML_DESCRIPTION</description>

    <targetplatform name="joomla" version="5\.[0-9]+|6\.[0-9]+" />

    <namespace path="src">Cybersalt\Component\Cstemplateintegrity</namespace>

    <scriptfile>script.php</scriptfile>

    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>
    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>
    <administration>
        <menu img="class:check-circle" link="option=com_cstemplateintegrity&amp;view=dashboard">COM_CSTEMPLATEINTEGRITY</menu>
        <submenu>
            <menu link="option=com_cstemplateintegrity&amp;view=dashboard">COM_CSTEMPLATEINTEGRITY_SUBMENU_DASHBOARD</menu>
            <menu link="option=com_cstemplateintegrity&amp;view=sessions">COM_CSTEMPLATEINTEGRITY_SUBMENU_SESSIONS</menu>
            <menu link="option=com_cstemplateintegrity&amp;view=actions">COM_CSTEMPLATEINTEGRITY_SUBMENU_ACTIONS</menu>
            <menu link="option=com_cstemplateintegrity&amp;view=backups">COM_CSTEMPLATEINTEGRITY_SUBMENU_BACKUPS</menu>
        </submenu>
        <files folder="admin">
            <filename>access.xml</filename>
            <filename>config.xml</filename>
            <folder>language</folder>
            <folder>services</folder>
            <folder>sql</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
        </files>
        <languages folder="admin/language">
            <language tag="en-GB">en-GB/com_cstemplateintegrity.ini</language>
            <language tag="en-GB">en-GB/com_cstemplateintegrity.sys.ini</language>
        </languages>
    </administration>

    <api>
        <files folder="api">
            <folder>language</folder>
            <folder>src</folder>
        </files>
        <languages folder="api/language">
            <language tag="en-GB">en-GB/com_cstemplateintegrity.ini</language>
        </languages>
    </api>

    <media destination="com_cstemplateintegrity" folder="media">
        <folder>css</folder>
        <folder>js</folder>
    </media>
</extension>
