<?xml version="1.0" encoding="utf-8"?>
<!--
    Cybersalt Template Integrity - ACL definitions

    csintegrity.view  : may read overrides, sessions, action log, backups (GET endpoints)
    csintegrity.write : may apply fixes, dismiss overrides, restore backups, create sessions/backups
                        (write-side endpoints + admin "Restore" / "Apply fix" actions)

    The standard core actions are also defined so site admins can map them
    in the Permissions tab. Defaults are restrictive; only Super Users
    inherit any permission until an admin grants explicitly.
-->
<access component="com_csintegrity">
    <section name="component">
        <action name="core.admin"   title="JACTION_ADMIN"   description="JACTION_ADMIN_COMPONENT_DESC" />
        <action name="core.manage"  title="JACTION_MANAGE"  description="JACTION_MANAGE_COMPONENT_DESC" />
        <action name="core.options" title="JACTION_OPTIONS" description="JACTION_OPTIONS_COMPONENT_DESC" />

        <action name="csintegrity.view"
                title="COM_CSINTEGRITY_ACTION_VIEW_TITLE"
                description="COM_CSINTEGRITY_ACTION_VIEW_DESC" />

        <action name="csintegrity.write"
                title="COM_CSINTEGRITY_ACTION_WRITE_TITLE"
                description="COM_CSINTEGRITY_ACTION_WRITE_DESC" />
    </section>
</access>
